# 千问 API Key (从阿里云百炼获取: https://bailian.console.aliyun.com/)
DASHSCOPE_API_KEY=your_api_key_here

# 千问 WebSocket 地址（固定值，如需切换模型可修改）
QWEN_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime?model=qwen3.5-livetranslate-flash-realtime

# 豆包 API Key (从火山引擎获取: https://console.volcengine.com/speech/new)
VOLC_API_KEY=your_api_key_here

# 服务端口
SERVER_PORT=8000